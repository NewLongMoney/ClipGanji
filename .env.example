# Database (required)
DATABASE_URL=
DIRECT_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (clipper login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Nodemailer / Gmail) — contact form & clipper signup notifications
# Use Gmail address and an App Password (not your normal password)
EMAIL_USER=
EMAIL_PASS=

# Optional: admin email for access control (defaults to clipganji@gmail.com)
# ADMIN_EMAIL=
